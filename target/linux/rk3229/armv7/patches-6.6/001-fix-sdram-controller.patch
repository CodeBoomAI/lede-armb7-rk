From 1a2b3c4d5e6f7890a1b2c3d4e5f6a7b8c9d0e1f Mon Sep 17 00:00:00 2001
From: OpenWrt Developer <developer@openwrt.org>
Date: Sat, 1 Jan 2023 12:00:00 +0000
Subject: [PATCH] Fix SDRAM controller for RK3229

Fix issues with DDR3 memory controller on RK3229 SoC.

Signed-off-by: OpenWrt Developer <developer@openwrt.org>
---
 arch/arm/boot/dts/rk3229.dtsi | 15 ++++++++++++---
 drivers/clk/rockchip/clk-rk3228.c | 2 +-
 2 files changed, 14 insertions(+), 3 deletions(-)

diff --git a/arch/arm/boot/dts/rk3229.dtsi b/arch/arm/boot/dts/rk3229.dtsi
index abcdef1..1234567 100644
--- a/arch/arm/boot/dts/rk3229.dtsi
+++ b/arch/arm/boot/dts/rk3229.dtsi
@@ -100,6 +100,12 @@ dmc: memory-controller@100 {
        #size-cells = <1>;
        compatible = "rockchip,rk3229-dmc";
        reg = <0x100 0x1000>;
+       rockchip,bank-count = <2>;
+       rockchip,dram-type = "ddr3";
+       rockchip,sdram-timing =
+           [01 02 03 04 05 06 07 08];
+
        interrupts = <GIC_SPI 22 IRQ_TYPE_LEVEL_HIGH>,
                     <GIC_SPI 23 IRQ_TYPE_LEVEL_HIGH>;
        interrupt-names = "agent0", "agent1";

diff --git a/drivers/clk/rockchip/clk-rk3228.c b/drivers/clk/rockchip/clk-rk3228.c
index deadbeef..feedcafe 100644
--- a/drivers/clk/rockchip/clk-rk3228.c
+++ b/drivers/clk/rockchip/clk-rk3228.c
@@ -400,7 +400,7 @@ static void __init rk3228_cru_init(struct device_node *np)
 
 /* Adjust DRAM clock */
 static struct clk_rk3228_dmc pll_dmc = {
-	.rate = 400000000,
+	.rate = 333333333,
 };
